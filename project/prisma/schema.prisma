datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

model orders {
  id                Int @id @default(autoincrement())
  wheels            Int
  windshield_wipers Int
  radios            Int
}

model users {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  name     String
  bio      String

  twitter   String?
  instagram String?
  facebook  String?

  profilePic String?

  photos  photo[]
  friends Int[]

  createdAt DateTime @default(now())
  sentRequests friendrequest[] @relation("RequestSender")
  receivedRequests friendrequest[] @relation("RequestReceiver")
}
enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model friendrequest {
  id         Int     @id @default(autoincrement())

  senderId   Int
  receiverId Int

  sender      users @relation("RequestSender", fields: [senderId], references: [id])
  receiver    users @relation("RequestReceiver", fields: [receiverId], references: [id])

  status FriendRequestStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([senderId, receiverId])
}
model photo {

  id        Int @id @default(autoincrement())

  imageUrl  String

  ownerId   Int

  owner users @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
}