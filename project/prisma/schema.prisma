datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

model orders {
  id                Int @id @default(autoincrement())
  wheels            Int
  windshield_wipers Int
  radios            Int
}

model users {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  name     String
  bio      String

  twitter   String?
  instagram String?
  facebook  String?

  profilePic String?

  photos  String[]
  friends String[]

  createdAt DateTime @default(now())
}
